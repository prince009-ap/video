{
  "name": "Quick Video Call",
  "short_name": "Video Call",
  "description": "Installable app for quick one-to-one video calls.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "background_color": "#081120",
  "theme_color": "#0f172a",
  "orientation": "portrait-primary",
  "permissions": {
    "camera": {
      "allowed": true,
      "persistent": true
    },
    "microphone": {
      "allowed": true,
      "persistent": true
    }
  },
  "background": {
    "service_worker": "sw.js",
    "type": "module"
  },
  "icons": [
    {
      "src": "/icons/icon-192.svg",
      "sizes": "192x192",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    },
    {
      "src": "/icons/icon-512.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    }
  ]
}
